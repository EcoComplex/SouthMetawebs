  pages = {134--151},
  publisher = {Springer},
  address = {Berlin, Heidelberg},
  doi = {10.1007/978-3-642-86940-2_10},
  urldate = {2025-07-08},
  abstract = {Let A be a real m\texttimes n matrix with m{$\geqq$}n. It is well known (cf. [4]) that(1)\$\$A = U\textbackslash sum \textbraceleft V\textasciicircum T\textbraceright\$\$where\$\$\textbraceleft U\textasciicircum T\textbraceright U = \textbraceleft V\textasciicircum T\textbraceright V = V\textbraceleft V\textasciicircum T\textbraceright{} = \textbraceleft I\_n\textbraceright\textbraceleft\textbackslash text\textbraceleft{} and \textbraceright\textbraceright\textbackslash sum \textbraceleft\textbackslash text\textbraceleft{} = diag(\textbraceright\textbraceright\textbraceleft\textbackslash sigma \_\textbraceleft\textbackslash text\textbraceleft 1\textbraceright\textbraceright\textbraceright\textbraceleft\textbackslash text\textbraceleft,\textbraceright\textbraceright{} \textbackslash ldots \textbraceleft\textbackslash text\textbraceleft,\textbraceright\textbraceright\textbraceleft\textbackslash sigma \_n\textbraceright\textbraceleft\textbackslash text\textbraceleft )\textbraceright\textbraceright\textbraceleft\textbackslash text\textbraceleft.\textbraceright\textbraceright\$\$The matrix U consists of n orthonormalized eigenvectors associated with the n largest eigenvalues of AAT, and the matrix V consists of the orthonormalized eigenvectors of ATA. The diagonal elements of {$\sum$} are the non-negative square roots of the eigenvalues of ATA; they are called singular values. We shall assume that\$\$\textbraceleft\textbackslash sigma \_1\textbraceright{} \textbackslash geqq \textbraceleft\textbackslash sigma \_2\textbraceright{} \textbackslash geqq \textbackslash cdots \textbackslash geqq \textbraceleft\textbackslash sigma \_n\textbraceright{} \textbackslash geqq 0.\$\$Thus if rank(A)=r, {$\sigma$}r+1 = {$\sigma$}r+2={$\cdots$}={$\sigma$}n= 0. The decomposition (1) is called the singular value decomposition (SVD).},
  isbn = {978-3-642-86940-2},
  langid = {english}
}

